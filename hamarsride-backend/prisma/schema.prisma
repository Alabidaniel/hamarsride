// Prisma schema for HamarsRide

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  rider
  admin
}

enum BusinessType {
  restaurant
  shop
}

model User {
  id            String         @id @default(cuid())
  firebaseUid   String         @unique
  name          String
  email         String         @unique
  phone         String?
  altPhone      String?
  dateOfBirth   DateTime?
  gender        String?
  photoUrl      String?
  role          UserRole       @default(customer)
  createdAt     DateTime       @default(now())
  addresses     Address[]
  orders        Order[]
  cartItems     CartItem[]
  notifications Notification[]
  payments     Payment[]
  receipts      Receipt[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String
  details   String
  notes     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Restaurant {
  id        String     @id @default(cuid())
  name      String
  type      BusinessType @default(restaurant)
  image     String?
  rating    Float?
  time      String?
  fee       String?
  open      Boolean    @default(true)
  createdAt DateTime   @default(now())
  menuItems MenuItem[]

  @@index([type])
}

model MenuItem {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  description  String? @db.Text
  price        Int
  image        String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  cartItems    CartItem[]
}

enum OrderStatus {
  pending
  accepted
  picked_up
  processing
  delivered
  rejected
  cancelled
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  status      OrderStatus @default(pending)
  address     String
  instruction String?
  rejectionReason String? @db.Text
  subtotal    Int
  deliveryFee Int
  total       Int
  pickup      String?
  dropoff     String?
  createdAt   DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
  payments Payment[]
  receipts Receipt[]
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  name    String
  qty     Int
  price   Int

  order Order @relation(fields: [orderId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model CartItem {
  id         String   @id @default(cuid())
  userId     String
  menuItemId String?
  name       String
  price      Int
  image      String?
  qty        Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id])
}






enum PaymentStatus {
  submitted
  verified
  rejected
}

model Payment {
  id         String        @id @default(cuid())
  userId     String
  orderId    String
  amount     Int
  receiptUrl String
  status     PaymentStatus @default(submitted)
  createdAt  DateTime      @default(now())

  user  User  @relation(fields: [userId], references: [id])
  order Order @relation(fields: [orderId], references: [id])
}

model Receipt {
  id           String   @id @default(cuid())
  orderId      String
  userId       String
  receiptNumber String  @unique
  items        Json
  subtotal     Int
  deliveryFee  Int
  total        Int
  address      String
  instruction  String?
  generatedBy  String
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}
